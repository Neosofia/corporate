{
  "private": true,
  "type": "module",
  "scripts": {
    "prod": "pnpm run build && pnpm run serve",
    "dev": "DEBUG=vite:time* react-router dev",
    "docs:generate": "pnpm exec neosofia-docs qms",
    "build:client": "DEBUG=vite:time* react-router build",
    "build": "pnpm run docs:generate && pnpm run build:client",
    "serve": "DEBUG=vite:time* vite serve build/client --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@neosofia/docs-generator": "github:neosofia/docs",
    "@react-router/node": "^7.14.2",
    "@tanstack/react-form": "^1.29.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isbot": "^5.1.39",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router": "^7.14.2",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.1"
  },
  "pnpm": {
    "overrides": {
      "yaml": "2.8.3"
    },
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@heroicons/react": "^2.2.0",
    "@react-router/dev": "^7.14.2",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "postcss": "^8.5.12",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vite-multiple-assets": "^2.2.6"
  }
}
