{
    "name": "React Dev Container",
    "image": "mcr.microsoft.com/devcontainers/typescript-node:dev-22-bookworm",
    "features": {
        "ghcr.io/devcontainers/features/git-lfs:1": {}
    },
    "mounts": [
        "type=volume,target=${containerWorkspaceFolder}/node_modules",
        "type=volume,target=${containerWorkspaceFolder}/.pnpm-store"
    ],
    "postCreateCommand": "git lfs install && git lfs pull && sudo chown -R node:node * && pnpm install",
    "customizations": {
        "vscode": {
            "extensions": [
                "streetsidesoftware.code-spell-checker",
                "SimonSiefke.svg-preview",
                "ciarant.vscode-structurizr",
                "tomoki1207.pdf",
                "github.vscode-github-actions",
                "bierner.github-markdown-preview",
                "bierner.markdown-footnotes",
                "bierner.markdown-emoji",
                "bierner.markdown-checkbox",
                "bierner.markdown-preview-github-styles",
                "bierner.markdown-yaml-preamble",
                "darkriszty.markdown-table-prettify",
                "msjsdiag.vscode-react-native",
                "bradlc.vscode-tailwindcss"
            ]
        }
    }
}